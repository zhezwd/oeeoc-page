---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 获取所有文章
const articles = await getCollection('articles', ({ data }) => {
  return !data.draft;
});

// 按日期排序
const sortedArticles = articles.sort((a, b) => 
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 格式化日期
function formatDate(date: Date) {
  return new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  }).format(date);
}
---

<BaseLayout 
  title="文章 - oeeoc"
  description="oeeoc的文章列表"
>
  <div class="articles-page">
    <!-- 导航栏 -->
    <nav class="nav-bar">
      <a href="/" class="nav-back">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        <span>返回</span>
      </a>
      <h1 class="nav-title">文章</h1>
      <span class="article-count">{sortedArticles.length} 篇</span>
    </nav>
    
    <!-- 文章列表 -->
    <div class="articles-container">
      {sortedArticles.length === 0 ? (
        <div class="empty-state">
          <p class="text-secondary">暂无文章</p>
          <a href="/admin" class="empty-link">去后台创建第一篇</a>
        </div>
      ) : (
        <ul class="articles-list">
          {sortedArticles.map((article, index) => (
            <li class="article-item" style={`--delay: ${index * 0.05}s`}>
              <a href={`/articles/${article.slug}`} class="article-link">
                <article class="article-card">
                  {article.data.heroImage && (
                    <div class="article-image">
                      <img src={article.data.heroImage} alt={article.data.title} loading="lazy">
                    </div>
                  )}
                  <div class="article-content">
                    <div class="article-meta">
                      <time class="article-date">{formatDate(article.data.pubDate)}</time>
                      {article.data.tags && article.data.tags.length > 0 && (
                        <span class="article-tags">
                          {article.data.tags.slice(0, 2).map(tag => (
                            <span class="tag">{tag}</span>
                          ))}
                        </span>
                      )}
                    </div>
                    <h2 class="article-title">{article.data.title}</h2>
                    {article.data.description && (
                      <p class="article-description">{article.data.description}</p>
                    )}
                  </div>
                  <div class="article-arrow">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </div>
                </article>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
    
    <!-- 返回顶部 -->
    <button class="back-to-top" id="backToTop" aria-label="返回顶部">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 19V5M5 12l7-7 7 7"/>
      </svg>
    </button>
  </div>
  
  <style>
    .articles-page {
      min-height: 100vh;
      padding: var(--space-2xl) var(--space-3xl);
      max-width: 900px;
      margin: 0 auto;
    }
    
    /* 导航栏 */
    .nav-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-lg) 0;
      margin-bottom: var(--space-2xl);
      border-bottom: 1px solid var(--glass-border);
      position: sticky;
      top: 0;
      background: var(--bg-primary);
      z-index: 100;
    }
    
    .nav-back {
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      color: var(--text-secondary);
      font-size: 0.875rem;
      transition: color 0.2s ease;
    }
    
    .nav-back:hover {
      color: var(--text-primary);
    }
    
    .nav-title {
      font-size: 1.25rem;
      font-weight: 600;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
    
    .article-count {
      font-size: 0.875rem;
      color: var(--text-tertiary);
    }
    
    /* 文章列表 */
    .articles-container {
      padding-bottom: var(--space-4xl);
    }
    
    .articles-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-md);
    }
    
    .article-item {
      opacity: 0;
      transform: translateY(20px);
      animation: fade-in-up 0.5s var(--ease-smooth) forwards;
      animation-delay: var(--delay, 0s);
    }
    
    .article-link {
      display: block;
      text-decoration: none;
    }
    
    .article-card {
      display: flex;
      align-items: center;
      gap: var(--space-lg);
      padding: var(--space-lg);
      border-radius: var(--radius-lg);
      background: var(--bg-glass-light);
      border: 1px solid transparent;
      transition: all 0.3s var(--ease-smooth);
    }
    
    .article-card:hover {
      background: var(--bg-glass);
      border-color: var(--glass-border);
      transform: translateX(5px);
    }
    
    .article-image {
      flex-shrink: 0;
      width: 80px;
      height: 80px;
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    
    .article-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }
    
    .article-card:hover .article-image img {
      transform: scale(1.05);
    }
    
    .article-content {
      flex: 1;
      min-width: 0;
    }
    
    .article-meta {
      display: flex;
      align-items: center;
      gap: var(--space-md);
      margin-bottom: var(--space-sm);
      flex-wrap: wrap;
    }
    
    .article-date {
      font-size: 0.75rem;
      color: var(--text-tertiary);
    }
    
    .article-tags {
      display: flex;
      gap: var(--space-xs);
    }
    
    .tag {
      font-size: 0.6875rem;
      padding: 2px 8px;
      border-radius: var(--radius-full);
      background: var(--bg-tertiary);
      color: var(--text-secondary);
    }
    
    .article-title {
      font-size: 1.125rem;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: var(--space-xs);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .article-description {
      font-size: 0.875rem;
      color: var(--text-secondary);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    
    .article-arrow {
      flex-shrink: 0;
      color: var(--text-muted);
      transition: all 0.3s ease;
    }
    
    .article-card:hover .article-arrow {
      color: var(--accent);
      transform: translateX(5px);
    }
    
    /* 空状态 */
    .empty-state {
      text-align: center;
      padding: var(--space-4xl) 0;
    }
    
    .empty-link {
      display: inline-block;
      margin-top: var(--space-md);
      padding: var(--space-sm) var(--space-lg);
      background: var(--accent);
      color: white;
      border-radius: var(--radius-md);
      font-size: 0.875rem;
      transition: opacity 0.2s ease;
    }
    
    .empty-link:hover {
      opacity: 0.9;
    }
    
    /* 返回顶部 */
    .back-to-top {
      position: fixed;
      bottom: var(--space-2xl);
      right: var(--space-2xl);
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--bg-glass);
      border: 1px solid var(--glass-border);
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      visibility: hidden;
      transform: translateY(20px);
      transition: all 0.3s var(--ease-smooth);
      z-index: 100;
    }
    
    .back-to-top.visible {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    
    .back-to-top:hover {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }
    
    /* 手机端适配 */
    @media (max-width: 768px) {
      .articles-page {
        padding: var(--space-lg) var(--space-md);
      }
      
      .nav-title {
        position: static;
        transform: none;
        font-size: 1rem;
      }
      
      .article-card {
        flex-wrap: wrap;
        gap: var(--space-md);
      }
      
      .article-image {
        width: 60px;
        height: 60px;
      }
      
      .article-arrow {
        display: none;
      }
      
      .back-to-top {
        bottom: var(--space-lg);
        right: var(--space-lg);
        width: 44px;
        height: 44px;
      }
    }
    
    /* 平板适配 */
    @media (min-width: 769px) and (max-width: 1024px) {
      .articles-page {
        padding: var(--space-xl) var(--space-2xl);
      }
    }
  </style>
  
  <script>
    // Lenis 平滑滚动
    let lenis;
    if (typeof Lenis !== 'undefined') {
      lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        direction: 'vertical',
        gestureDirection: 'vertical',
        smooth: true,
        mouseMultiplier: 1,
        smoothTouch: false,
        touchMultiplier: 2,
        infinite: false,
      });
      
      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);
      
      // 连接 GSAP ScrollTrigger
      if (typeof gsap !== 'undefined' && gsap.registerPlugin) {
        gsap.registerPlugin(ScrollTrigger);
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0);
      }
    }
    
    // 返回顶部
    const backToTop = document.getElementById('backToTop');
    
    window.addEventListener('scroll', () => {
      if (window.scrollY > 500) {
        backToTop?.classList.add('visible');
      } else {
        backToTop?.classList.remove('visible');
      }
    }, { passive: true });
    
    backToTop?.addEventListener('click', () => {
      if (lenis) {
        lenis.scrollTo(0);
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });
    
    // GSAP 滚动动画
    if (typeof gsap !== 'undefined' && gsap.registerPlugin) {
      gsap.registerPlugin(ScrollTrigger);
      
      // 导航栏滚动效果
      ScrollTrigger.create({
        start: 'top -100',
        end: 99999,
        toggleClass: { className: 'scrolled', targets: '.nav-bar' }
      });
    }
  </script>
</BaseLayout>
